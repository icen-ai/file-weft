# syntax=docker/dockerfile:1.7

FROM eclipse-temurin:21-jdk-jammy@sha256:9d8dcf999b0bce2453e913823595a5ff2a4e8e9e5d5241b45280d0ff069818ec AS build

WORKDIR /workspace
COPY . .
RUN --mount=type=cache,id=fileweft-dev-gradle-jdk21,target=/root/.gradle,sharing=locked \
    sed -i 's/\r$//' gradlew \
    && chmod +x gradlew \
    && ./gradlew --no-daemon --no-configuration-cache :fileweft-dev:installDist

FROM eclipse-temurin:21-jre-jammy@sha256:d63bd8d9b171999cbed8576f2c76e874dd4856791a358536e5c4d407e77edc13

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --system --uid 10001 --create-home fileweft

WORKDIR /opt/fileweft
COPY --from=build --chown=fileweft:fileweft /workspace/fileweft-dev/build/install/fileweft-dev /opt/fileweft

USER fileweft
ENTRYPOINT ["java", "-cp", "/opt/fileweft/lib/*"]
