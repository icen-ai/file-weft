FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	INSERT_RESULT_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            INSERT INTO fw_wf_effect_result(\n                id, tenant_id, instance_id, effect_id, result_type, outcome_code, result_digest,\n                result_payload, retry_time, completed_time, result_version, created_time, updated_time\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	RECOVER_EFFECT_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            UPDATE fw_wf_effect SET delivery_status = ?, outcome_digest = ?,\n                record_version = record_version + 1, lease_id = NULL, worker_id = NULL,\n                lease_acquired_time = NULL, lease_expires_time = NULL, execution_phase = NULL,\n                next_attempt_time = NULL, updated_time = ?\n            WHERE tenant_id = ? AND id = ? AND record_version = ?\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	RELEASE_RECOVERED_JOB_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            UPDATE fw_wf_job SET job_status = ?, failure_digest = ?, record_version = record_version + 1,\n                lease_id = NULL, worker_id = NULL, lease_acquired_time = NULL,\n                lease_expires_time = NULL, execution_mode = NULL, claim_request_digest = NULL,\n                updated_time = ?\n            WHERE tenant_id = ? AND id = ? AND record_version = ?\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	SELECT_CLAIMS_BY_REQUEST_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            SELECT j.id AS job_id, j.tenant_id, j.instance_id, j.effect_id,\n                e.effect_code, e.delivery_status AS effect_status, e.execution_phase AS effect_phase,\n                e.checkpoint_digest AS effect_checkpoint_digest, e.record_version AS effect_version,\n                e.fencing_token AS effect_fencing_token, e.lease_id AS effect_lease_id,\n                e.lease_expires_time AS effect_lease_expires_time,\n                j.record_version AS job_version, j.fencing_token AS job_fencing_token,\n                j.lease_id AS job_lease_id, j.worker_id AS job_worker_id,\n                j.lease_acquired_time AS job_lease_acquired_time,\n                j.lease_expires_time AS job_lease_expires_time,\n                j.execution_mode, j.claim_request_digest\n            FROM fw_wf_job j\n            JOIN fw_wf_effect e ON e.tenant_id = j.tenant_id AND e.id = j.effect_id\n            JOIN fw_wf_instance i ON i.tenant_id = j.tenant_id AND i.id = j.instance_id\n        \n            WHERE j.tenant_id = ? AND j.claim_request_digest = ? AND j.worker_id = ?\n                AND j.lease_expires_time > ?\n            ORDER BY j.created_time, j.id\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	SELECT_COLUMNS	Ljava/lang/String;	access=public,static,final	constant=string:"\n            SELECT j.id AS job_id, j.tenant_id, j.instance_id, j.effect_id,\n                e.effect_code, e.delivery_status AS effect_status, e.execution_phase AS effect_phase,\n                e.checkpoint_digest AS effect_checkpoint_digest, e.record_version AS effect_version,\n                e.fencing_token AS effect_fencing_token, e.lease_id AS effect_lease_id,\n                e.lease_expires_time AS effect_lease_expires_time,\n                j.record_version AS job_version, j.fencing_token AS job_fencing_token,\n                j.lease_id AS job_lease_id, j.worker_id AS job_worker_id,\n                j.lease_acquired_time AS job_lease_acquired_time,\n                j.lease_expires_time AS job_lease_expires_time,\n                j.execution_mode, j.claim_request_digest\n            FROM fw_wf_job j\n            JOIN fw_wf_effect e ON e.tenant_id = j.tenant_id AND e.id = j.effect_id\n            JOIN fw_wf_instance i ON i.tenant_id = j.tenant_id AND i.id = j.instance_id\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	SELECT_EXPIRED_PROVIDER_JOB_IDS_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            SELECT j.id\n            FROM fw_wf_job j\n            WHERE j.tenant_id = ? AND j.job_type = ?\n                AND EXISTS (\n                    SELECT 1\n                    FROM fw_wf_effect e\n                    JOIN fw_wf_instance i ON i.tenant_id = j.tenant_id AND i.id = j.instance_id\n                    WHERE e.tenant_id = j.tenant_id AND e.id = j.effect_id\n                    AND e.delivery_status = ?\n                    AND i.status IN ('running', 'waiting')\n                    AND e.execution_phase = ? AND e.lease_expires_time <= ?\n                )\n            ORDER BY j.created_time, j.id\n            LIMIT ?\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	SELECT_JOB_BY_ID_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            SELECT j.id AS job_id, j.tenant_id, j.instance_id, j.effect_id,\n                e.effect_code, e.delivery_status AS effect_status, e.execution_phase AS effect_phase,\n                e.checkpoint_digest AS effect_checkpoint_digest, e.record_version AS effect_version,\n                e.fencing_token AS effect_fencing_token, e.lease_id AS effect_lease_id,\n                e.lease_expires_time AS effect_lease_expires_time,\n                j.record_version AS job_version, j.fencing_token AS job_fencing_token,\n                j.lease_id AS job_lease_id, j.worker_id AS job_worker_id,\n                j.lease_acquired_time AS job_lease_acquired_time,\n                j.lease_expires_time AS job_lease_expires_time,\n                j.execution_mode, j.claim_request_digest\n            FROM fw_wf_job j\n            JOIN fw_wf_effect e ON e.tenant_id = j.tenant_id AND e.id = j.effect_id\n            JOIN fw_wf_instance i ON i.tenant_id = j.tenant_id AND i.id = j.instance_id\n         WHERE j.tenant_id = ? AND j.id = ?"
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	SELECT_JOB_ID_BY_ID_FOR_UPDATE_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"SELECT id FROM fw_wf_job WHERE tenant_id = ? AND id = ? FOR UPDATE"
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	SELECT_READY_JOB_IDS_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            SELECT j.id\n            FROM fw_wf_job j\n            WHERE j.tenant_id = ? AND j.job_type = ? AND j.available_time <= ?\n                AND (j.lease_expires_time IS NULL OR j.lease_expires_time <= ?)\n                AND EXISTS (\n                    SELECT 1\n                    FROM fw_wf_effect e\n                    JOIN fw_wf_instance i ON i.tenant_id = j.tenant_id AND i.id = j.instance_id\n                    WHERE e.tenant_id = j.tenant_id AND e.id = j.effect_id\n                    AND i.status IN ('running', 'waiting')\n                    AND (\n                        e.delivery_status = ? OR\n                        (e.delivery_status = ? AND e.next_attempt_time <= ?) OR\n                        (e.delivery_status = ? AND e.execution_phase = ? AND e.lease_expires_time <= ?) OR\n                        (e.delivery_status = ? AND EXISTS (\n                            SELECT 1 FROM fw_wf_effect_result r\n                            WHERE r.tenant_id = j.tenant_id AND r.effect_id = j.effect_id\n                        )) OR\n                        (e.delivery_status = ? AND EXISTS (\n                            SELECT 1 FROM fw_wf_effect_result r\n                            WHERE r.tenant_id = j.tenant_id AND r.effect_id = j.effect_id\n                        ))\n                    )\n                )\n            ORDER BY j.available_time, j.created_time, j.id\n            LIMIT ?\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowReadyEffectJobQueue	SELECT_RESULT_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            SELECT result_type, outcome_code, result_digest, result_payload, retry_time, completed_time\n            FROM fw_wf_effect_result WHERE tenant_id = ? AND effect_id = ?\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowRuntimePersistence	ACKNOWLEDGE_EFFECT_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            UPDATE fw_wf_effect\n            SET delivery_status = ?, acknowledgement_kind = ?, acknowledgement_receipt_digest = ?,\n                record_version = record_version + 1, updated_time = ?\n            WHERE tenant_id = ? AND id = ? AND record_version = ?\n        "
FIELD	ai.icen.fw.workflow.persistence.jdbc.JdbcWorkflowRuntimePersistence	CHECKPOINT_EFFECT_SQL	Ljava/lang/String;	access=public,static,final	constant=string:"\n            UPDATE fw_wf_effect\n            SET execution_phase = ?, checkpoint_sequence = ?, checkpoint_digest = ?,\n                record_version = record_version + 1, updated_time = ?\n            WHERE tenant_id = ? AND id = ? AND record_version = ? AND lease_id = ? AND fencing_token = ?\n        "
