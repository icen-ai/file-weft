# Browser-visible source URLs are intentionally unsupported. Only opaque,
# administrator-approved profile IDs may be listed here.
FLOWWEFT_CONSOLE_DEFAULT_LOCALE=zh
FLOWWEFT_CONSOLE_SOURCE_PROFILE_IDS=
# Optional server-only versioned definitions. IDs must exactly match the
# allowlist above. Origins and authentication modes are projected to a safe
# summary; the origin and exchange path never enter a browser DTO. A host
# compatibility profile may declare, for example:
# {"version":1,"profiles":[{"id":"primary","displayName":"Primary","baseUrl":"https://flowweft.example","authenticationModes":["HOST_TOKEN_EXCHANGE"],"api":{"allowPrivateNetwork":false},"hostTokenExchange":{"endpointPath":"/internal/console/token-exchange","allowPrivateNetwork":false}}]}
FLOWWEFT_CONSOLE_SOURCE_PROFILES_JSON=
# Exact browser-visible Console origin. It is never derived from Host or
# X-Forwarded-* headers. Required when production authentication is enabled.
FLOWWEFT_CONSOLE_PUBLIC_ORIGIN=https://console.example.com
FLOWWEFT_CONSOLE_SESSION_COOKIE_NAME=__Host-flowweft_session
FLOWWEFT_CONSOLE_SECURE_COOKIES=true
FLOWWEFT_CONSOLE_SESSION_TTL_SECONDS=3600
FLOWWEFT_CONSOLE_AUTHORIZATION_TTL_SECONDS=300
FLOWWEFT_CONSOLE_MAX_PENDING_AUTHORIZATIONS=1000
FLOWWEFT_CONSOLE_MAX_SESSIONS=10000
# Recommended for multi-replica production authentication. Redis and the
# encryption keyring must be configured together. Production requires rediss://.
# Credentials, if present, stay server-side and must come from a secret store.
FLOWWEFT_CONSOLE_REDIS_URL=
FLOWWEFT_CONSOLE_REDIS_KEY_PREFIX=flowweft:console:v1
# JSON array, newest/active key first. Each key is exactly 32 random bytes in
# canonical unpadded base64url form. Keep previous keys during rotation so
# existing sessions remain readable; at most four keys are accepted.
# Example shape only: [{"id":"2026_07","key":"<43-character-base64url>"}]
FLOWWEFT_CONSOLE_SESSION_ENCRYPTION_KEYS_JSON=
# Fallback only when Redis is intentionally absent. Production authentication
# remains unavailable until the operator acknowledges exactly one Console replica.
FLOWWEFT_CONSOLE_SINGLE_REPLICA_SESSION_STORE_ACK=false
